post_extract() {
	vsrcextract -C libs/webassembly/phc-winner-argon2 "${_argonver}.tar.gz"
	vsrcextract -C libs/webassembly/liboqs "${_liboqsver}.tar.gz"
	vsrcextract -C libs/Signal-FTS5-Extension "${_fts5ver}.tar.gz"
}

pre_build() {
	fnm install ${_nodever}
    eval "$(fnm env --shell bash)"
    fnm use ${_nodever}
	npm ci
}

do_build() {
	# Manually build sqlcipher extension to avoid build failure
	pushd node_modules/@signalapp/sqlcipher/deps/extension
	cargo build --release --target ${XBPS_RUST_TARGET}
	popd

	npm run build-packages
	node desktop --custom-desktop-release --unpacked
}

do_install() {
	:
}