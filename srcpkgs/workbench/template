skip_extraction="
 ${_trollver}.tar.gz
 ${_demosver}.tar.gz
 gi-typescript-definitions-${_gitypesver}.tar.gz
"

post_extract() {
	vsrcextract -C troll "${_trollver}.tar.gz"
	vsrcextract -C demos "${_demosver}.tar.gz"
	vsrcextract -C gi-types "gi-typescript-definitions-${_gitypesver}.tar.gz"
}

post_install() {
	MESON_SOURCE_ROOT="$(pwd)" build-aux/library.js \
		"${DESTDIR}/usr/share/re.sonny.Workbench"
}

workbench-devel_package() {
	short_desc+=" - development files"
	depends="${sourcepkg}>=${version}_${revision}"
	pkg_install() {
		vmove usr/include
		vmove usr/share/vala
		vmove usr/share/gir-1.0
		vmove usr/lib/*.so
	}
}
