# Template file for 'element-desktop'
pkgname=element-desktop
version=1.12.21
revision=1
_electronver=35
build_helper=rust
conf_files="/etc/element-desktop/config.json"
hostmakedepends="pnpm rust python3 yarn cargo pkg-config"
makedepends="electron${_electronver}-devel openssl-devel
 sqlcipher-devel"
depends="electron${_electronver}"
short_desc="Glossy Matrix collaboration client, desktop version"
maintainer="Orphaned <orphan@voidlinux.org>"
license="Apache-2.0"
homepage="https://element.io"
changelog="https://github.com/element-hq/element-web/raw/refs/heads/develop/apps/desktop/CHANGELOG.md"
distfiles="https://github.com/element-hq/element-web/archive/refs/tags/v${version}.tar.gz"
checksum=bbf87817f7f60ee034e58acba1f937954137f0fbc4527885ae38851f3757512c
replaces="riot-desktop>=0"

pre_build() {
	sed -i "s/11.2.2.*/11.5.1\",/" package.json
	pnpm install --frozen-lockfile

	cd apps/desktop
	sed -i 's/target: \["tar.gz", "deb"\]/target: ["dir"]/' electron-builder.ts
	sed -i 's|"https://packages.element.io/desktop/update/"|null|' element.io/release/config.json
	pnpm install --frozen-lockfile
}

do_build() {
	export SQLCIPHER_BUNDLED=1

	cd apps/desktop

	pnpm run build:native
	pnpm run build "--publish never -c.electronVersion=\"$(cat /usr/lib/electron${_electronver}/version)\" -c.electronDist=\"/usr/lib/electron${_electronver}\""
}

do_install() {
	vmkdir /usr/lib/${pkgname}
	vcopy apps/desktop/dist/linux-unpacked/resources usr/lib/${pkgname}/resources
	echo '' >> dist/icons/size-list
	while read -r size; do
		if [ -n "$size" ]; then
			vinstall dist/icons/$size.png 644 "usr/share/icons/hicolor/$size/apps" element-desktop.png
		fi
	done <dist/icons/size-list

	sed "s/@electronver@/${_electronver}/g" ${FILESDIR}/${pkgname}.sh > ${TMPDIR}/${pkgname}.sh
	vbin ${TMPDIR}/${pkgname} ${pkgname}
	ln -s element-desktop "${DESTDIR}/usr/bin/riot-desktop"
}

riot-desktop_package() {
	depends="element-desktop>=${version}_${revision}"
	short_desc+=" (transitional dummy package)"
	metapackage=yes
}
