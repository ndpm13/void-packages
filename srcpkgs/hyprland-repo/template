# Template file for 'hyprland-repo'
pkgname=hyprland-repo
version=1
revision=1
short_desc="Binary repositories for installing Hyprland on Void Linux"
maintainer="Naz <ndpm13@ch-naseem.com>"
license="BSD-2-Clause"
homepage="https://github.com/Makrennel/hyprland-void/"
distfiles="https://raw.githubusercontent.com/Makrennel/hyprland-void/master/COPYING>COPYING"
checksum=b4eb122d536a26bf255b5f55ac29c234730ad9b7cfab69a34f502ea7ffff8877
skip_extraction="COPYING"

do_install() {
	vmkdir usr/share/xbps.d

	case "$XBPS_TARGET_MACHINE" in
		aarch64)
			echo "repository=https://raw.githubusercontent.com/Makrennel/hyprland-void/repository-aarch64-glibc" > \
				${DESTDIR}/usr/share/xbps.d/99-hyprland-void.conf
			;;
		aarch64-musl)
			echo "repository=https://raw.githubusercontent.com/Makrennel/hyprland-void/repository-aarch64-musl" > \
				${DESTDIR}/usr/share/xbps.d/99-hyprland-void.conf
			;;
		x86_64-musl)
			echo "repository=https://raw.githubusercontent.com/Makrennel/hyprland-void/repository-x86_64-musl" > \
				${DESTDIR}/usr/share/xbps.d/99-hyprland-void.conf
			;;
		x86_64)
			echo "repository=https://raw.githubusercontent.com/Makrennel/hyprland-void/repository-x86_64-glibc" > \
				${DESTDIR}/usr/share/xbps.d/99-hyprland-void.conf
			;;
		*)
			msg_error "$pkgname: unsupported architecture $XBPS_TARGET_MACHINE\n"
			;;
	esac

	vlicense ${XBPS_SRCDISTDIR}/${pkgname}-${version}/COPYING
}
