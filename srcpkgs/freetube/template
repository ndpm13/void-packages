# Template file for 'freetube'
pkgname=freetube
version=0.25.0
revision=1
_electronver=35
archs="x86_64"
hostmakedepends="pnpm"
depends="electron${_electronver}"
short_desc="Open source desktop YouTube player built with privacy in mind"
maintainer="Naz <ndpm13@ch-naseem.com>"
license="AGPL-3.0-only"
homepage="https://freetubeapp.io/"
changelog="https://github.com/FreeTubeApp/FreeTube/releases/"
distfiles="https://github.com/FreeTubeApp/FreeTube/archive/refs/tags/v${version}-beta.tar.gz"
checksum=3eae2b5fa67d943597c4c6aa6b07352fc0d350a6a4d6ad7750dc56f1e08970d3

pre_build() {
	pnpm install --frozen-lockfile
}

do_build() {
	pnpm run build
}

do_install() {
	vmkdir usr/lib/${pkgname}
	vcopy build/linux-unpacked/resources usr/lib/${pkgname}

	sed "s/@electronver@/${_electronver}/g" ${FILESDIR}/${pkgname}.sh > ${TMPDIR}/${pkgname}.sh
	vbin ${TMPDIR}/${pkgname}.sh ${pkgname}

	vinstall ${FILESDIR}/${pkgname}.desktop 644 usr/share/applications
	vinstall _icons/icon.svg 644 usr/share/pixmaps ${pkgname}.svg

	vlicense LICENSE
}
