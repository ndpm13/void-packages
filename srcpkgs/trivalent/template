do_extract() {
    mkdir -p ${DESTDIR}
    bsdtar --strip-components=1 -C ${DESTDIR} -x \
        --no-same-permissions --no-same-owner \
        -f ${XBPS_SRCDISTDIR}/${pkgname}-${version}/${pkgname}-${_version}.x86_64.rpm
}

do_install() {
	mv "${PKGDESTDIR}/usr/lib64" "${PKGDESTDIR}/usr/lib"
}