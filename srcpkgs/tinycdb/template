# Template file for 'tinycdb'
pkgname=tinycdb
version=0.81
revision=1
#archs="i686 x86_64"
#build_wrksrc=
build_style=gnu-makefile
#configure_args=""
make_build_args="all shared"
make_install_args="INSTALLPROG=cdb-shared mandir=/usr/share/man install-all install-sharedlib"
#conf_files=""
#make_dirs="/var/log/dir 0755 root root"
hostmakedepends=""
makedepends=""
depends=""
short_desc="Utility to manipulate constant databases (cdb)"
maintainer="Naz <ndpm13@ch-naseem.com>"
license="MIT"
homepage="https://www.corpit.ru/mjt/tinycdb.html"
#changelog=""
distfiles="https://www.corpit.ru/mjt/tinycdb/tinycdb-${version}.tar.gz"
checksum=469de2d445bf54880f652f4b6dc95c7cdf6f5502c35524a45b2122d70d47ebc2

do_build() {
    make CC="$CC" AR="$AR" RANLIB="$RANLIB" \
        CFLAGS="$CFLAGS" LDFLAGS="$LDFLAGS" LD="$CC" \
        PREFIX=/usr ${makejobs} all shared
}

tinycdb-devel_package() {
    short_desc="$short_desc - development files"
    depends="tinycdb-${version}_${revision}"
    pkg_install() {
        vmove usr/include
        vmove usr/lib/pkgconfig
        vmove "usr/lib/*.a"
        vmove "usr/lib/*.so"
    }
}