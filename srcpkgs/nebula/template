# Template file for 'nebula'
pkgname=nebula
version=1.11.0
revision=1
build_style=go
make_dirs="/etc/nebula 0750 root root"
go_import_path=github.com/slackhq/nebula
go_package="${go_import_path}/cmd/nebula ${go_import_path}/cmd/nebula-cert"
go_ldflags="-X main.Build=${version}"
