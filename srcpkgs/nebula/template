# argon2 test is broken on 32bit
# https://github.com/slackhq/nebula/pull/1598
case "$XBPS_TARGET_MACHINE" in
	i686) make_check_args="-skip Test_ca";;
esac

post_install() {
	vlicense LICENSE
	vsconf examples/config.yml
	vsv nebula
}
