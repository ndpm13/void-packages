post_extract() {
	vsrcextract -C test/third_party/posixtestsuite "${_posixtestver}.tar.gz"
	vsrcextract -C test/third_party/googletest "v${_googletestver}.tar.gz"
	vsrcextract -C test/third_party/wasi-test-suite "${_wasitestver}.tar.gz"
	vsrcextract -C llvm "${_llvmver}.tar.gz"
	vsrcextract -C binaryen "version_${_binaryenver}.tar.gz"
}

pre_install() {
	cd binaryen
	export CXXFLAGS+=" -Wno-error=maybe-uninitialized"
	cmake \
		-Bbuild \
		-GNinja \
		-DBUILD_TESTS=OFF \
		-DCMAKE_INSTALL_PREFIX=${DESTDIR}/usr
	ninja -C build && ninja -C build install

	vmkdir opt/emscripten/llvm
	cd ../llvm/llvm
	cmake \
		-Bbuild \
		-GNinja \
		-DLLVM_ENABLE_LIBXML2=OFF \
		-DLLVM_INCLUDE_EXAMPLES=OFF \
		-DCOMPILER_RT_BUILD_XRAY=OFF \
		-DCOMPILER_RT_INCLUDE_TESTS=OFF \
		-DCOMPILER_RT_ENABLE_IOS=OFF \
		-DCMAKE_INSTALL_PREFIX=${DESTDIR}/opt/emscripten/llvm \
		-DCMAKE_BUILD_TYPE=Release \
		-DCMAKE_SKIP_RPATH=ON \
		-DLLVM_BUILD_RUNTIME=OFF \
		-DLLVM_TOOL_LTO_BUILD=ON \
		-DLLVM_INSTALL_TOOLCHAIN_ONLY=ON \
		-DLLVM_INCLUDE_EXAMPLES=OFF \
		-DLLVM_INCLUDE_TESTS=OFF \
		-DLLVM_TARGETS_TO_BUILD="host;WebAssembly" \
		-DLLVM_ENABLE_PROJECTS="lld;clang" \
		-DCLANG_INCLUDE_TESTS=OFF
	ninja -C build && ninja -C build install
	local _stufftoremove="clang-check clang-cl clang-cpp
		clang-extdef-mapping clang-format clang-offload-bundler
		clang-refactor lld-link ld.lld llvm-lib"
	for bin in ${_stufftoremove}; do
		rm ${DESTDIR}/opt/emscripten/llvm/bin/${bin}
	done
	rm ${DESTDIR}/opt/emscripten/llvm/lib/libclang.so
	rm -r ${DESTDIR}/opt/emscripten/llvm/share
	local _stufftocopy="llvm-as llvm-dis FileCheck llc llvm-link
		llvm-mc llvm-readobj opt llvm-dwarfdump"
	for bin in ${_stufftocopy}; do
		vinstall ${DESTDIR}/opt/emscripten/llvm/llvm/build/bin/${bin} \
			755 ${DESTDIR}/opt/emscripten/llvm/bin/${bin}
	done

	python tools/maint/create_entry_points.py
}

do_install() {
	vmkdir usr/lib/${pkgname}
	DESTDIR=${DESTDIR}/usr/lib/${pkgname} make install

	vinstall ${FILESDIR}/emscripten-config 644 ${DESTDIR}/usr/lib/emscripten/.emscripten

	ls -lah ${DESTDIR}/usr/lib/${pkgname}

	vlicense LICENSE
}